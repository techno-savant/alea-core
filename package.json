{
  "name": "alea-core",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "preversion": "npm run typecheck",
    "postversion": "git push --follow-tags",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true
  }
}
